# Nina Pfatischer Yoga — Netlify env vars
#
# Copy to `.env` for local Netlify Functions work. In Netlify, import these
# values as environment variables with Functions/runtime scope enabled.

# API key from https://resend.com/api-keys with sending access.
RESEND_API_KEY=re_your_resend_api_key

# Sender shown on outbound messages. Must be on a Resend-verified sending domain.
EMAIL_FROM="Nina Pfatischer Yoga <nina@ninapfatischer.com>"

# Where visitor replies to customer confirmation emails should land.
EMAIL_REPLY_TO=nina@ninapfatischer.com

# Real mailbox that receives website leads through normal MX hosting.
# Do not use Resend Receiving here unless an inbound webhook/forwarder exists.
EMAIL_NOTIFICATION_TO=nina.real.receiving.inbox@example.com

# Optional BCC for internal notifications. Leave blank to skip.
EMAIL_NOTIFICATION_BCC=

# Set to "true" to email visitors a short receipt after the internal
# notification sends successfully.
EMAIL_CONFIRMATIONS_ENABLED=true
